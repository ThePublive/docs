  "logo": {
    "light": "https://cdn.prod.website-files.com/66826ebfedcc2d4a07df740c/6682747dedcc2d4a07e30c0e_publive-logo.svg",
    "dark": "https://img-cdn.publive.online/publive/logo/publive-white-full-logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://help.thepublive.com/support/solutions"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.thepublive.com/"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/the_Publive",
      "github": "https://github.com/ThePublive",
      "linkedin": "https://in.linkedin.com/company/the-publive"
